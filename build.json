{
    "name": "gerenciador-mercado-tibia",
    "productName": "Gerenciador de Mercado - Tibia",
    "version": "1.0.0",
    "main": "main.js",
    "type": "module",
    "scripts": {
        "start": "electron .",
        "pack": "electron-builder --dir",
        "build": "electron-builder"
    },
    "build": {
        "appId": "com.wanderli.gerenciadormercadotibia",
        "productName": "Gerenciador de Mercado - Tibia",
        "directories": {
            "output": "dist"
        },
        "files": [
            "main.js",
            "preload.cjs",
            "public/**/*",
            "src/**/*",
            "package.json"
        ],
        "win": {
            "target": [
                "nsis",
                "portable"
            ]
        },
        "nsis": {
            "oneClick": false,
            "allowToChangeInstallationDirectory": true,
            "createDesktopShortcut": true,
            "createStartMenuShortcut": true
        }
    }
}